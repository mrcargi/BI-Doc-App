# ════════════════════════════════════════════════════════════════
# PBI HUB — ENVIRONMENT CONFIGURATION
# Copy this to .env and update with your values
# NEVER commit .env to version control!
# ════════════════════════════════════════════════════════════════

# 🔐 CRITICAL SECURITY — Generate new values for production
# Generate SECRET_KEY with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
SECRET_KEY=your-generated-secret-key-here-change-this

# Admin account initial password (auto-generated if not set)
# ADMIN_DEFAULT_PASSWORD=your-secure-password-here

# Admin account email
ADMIN_DEFAULT_EMAIL=admin@yourdomain.com

# 🌐 CORS — Allowed origins for API requests
# For development: http://localhost:3000,http://localhost:8000
# For production: https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# 💾 DATABASE (optional, SQLite by default)
# For local development, SQLite is fine
# For production, use PostgreSQL or MySQL
# DATABASE_URL=postgresql://user:password@localhost/pbi_hub

# 🔔 NOTIFICATIONS (optional)
# Email configuration for sending notifications
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@yourdomain.com

# 📊 POWERBI INTEGRATION (future)
# POWERBI_TENANT_ID=your-azure-tenant-id
# POWERBI_CLIENT_ID=your-registered-app-id
# POWERBI_CLIENT_SECRET=your-client-secret

# 📈 DATABRICKS INTEGRATION (future)
# DATABRICKS_WORKSPACE=https://your-workspace.cloud.databricks.com
# DATABRICKS_TOKEN=your-api-token

# 🌙 APPLICATION
# ENV=production  # or 'development'
# DEBUG=false
# LOG_LEVEL=INFO

# 🔒 SECURITY
# SESSION_TIMEOUT_HOURS=12
# PASSWORD_MIN_LENGTH=12
# RATE_LIMIT_ATTEMPTS=5
# RATE_LIMIT_WINDOW_SECONDS=60

# ════════════════════════════════════════════════════════════════
# ⚠️  IMPORTANT SECURITY NOTES:
# ⚠️  1. NEVER share or commit your .env file
# ⚠️  2. Use strong, unique values for all secrets
# ⚠️  3. Rotate secrets regularly (at least annually)
# ⚠️  4. Use a secrets manager in production (Vault, AWS Secrets, etc)
# ⚠️  5. Restrict .env file permissions: chmod 600 .env
# ════════════════════════════════════════════════════════════════
